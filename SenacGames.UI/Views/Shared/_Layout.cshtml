@* =============================================================================
   SenacGames.UI - Layout Público (_Layout.cshtml)
   =============================================================================
   📌 CONCEITO: Layout (Master Page)
   O Layout define a estrutura HTML compartilhada por todas as páginas públicas.
   Inclui: <head>, navbar, footer, scripts.
   O conteúdo de cada página é inserido onde está o @RenderBody().

   DESIGN: Baseado no protótipo Stitch "SenacGames MVC Catalog System"
   Cores: Senac Blue (#004c97), Gold (#fdbf3f), Background (#f8f9fa)
   ============================================================================= *@

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SenacGames</title>
    <meta name="description" content="SenacGames - Catálogo de Games para Ensino" />

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- As fontes Google (Inter e Poppins) agora são importadas via site.css -->
    <!-- CSS Customizado -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Theme Toggle Script (Carregado antes do body para evitar FOUC) -->
    <script src="~/js/theme.js"></script>
</head>
<body>
    @* =====================================================================
       NAVBAR PÚBLICA — Design Stitch (Senac Blue)
       ===================================================================== *@
    <nav class="navbar navbar-expand-lg navbar-dark navbar-senac">
        <div class="container">
            @* Logo do sistema *@
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="SenacGames Logo" class="brand-logo" />
            </a>

            @* Botão hamburguer para mobile *@
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @* Links de navegação *@
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Games" asp-action="Index">
                            <i class="bi bi-collection"></i> Catálogo
                        </a>
                    </li>
                </ul>

                @* Botões de Tema e Autenticação *@
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item me-3">
                        <button onclick="toggleTheme()" class="btn btn-link nav-link p-0" title="Alternar Tema">
                            <i class="bi bi-moon-fill theme-toggle-icon fs-5"></i>
                        </button>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-gear"></i> Admin
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <span class="nav-link">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-light btn-sm ms-2">
                                    <i class="bi bi-box-arrow-right"></i> Sair
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm me-2" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-warning btn-sm" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus"></i> Registrar
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @* =====================================================================
       CONTEÚDO PRINCIPAL — Cada página insere seu conteúdo aqui
       ===================================================================== *@
    <main>
        @RenderBody()
    </main>

    @* =====================================================================
       FOOTER — Design Stitch
       ===================================================================== *@
    <footer class="footer-senac">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="mb-3">
                        <i class="bi bi-controller text-secondary"></i> SenacGames
                    </h5>
                    <p class="small mb-0">
                        Plataforma de catálogo de games desenvolvida para ensino de ASP.NET Core MVC.
                    </p>
                </div>
                <div class="col-md-3">
                    <h6 class="mb-2">Links</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Games" asp-action="Index">Catálogo</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="mb-2">Sobre</h6>
                    <ul class="list-unstyled small">
                        <li><a href="#">Privacidade</a></li>
                        <li><a href="#">Termos de Serviço</a></li>
                        <li><a href="#">Sobre o Senac</a></li>
                    </ul>
                </div>
            </div>
            <hr class="mt-4 mb-3" style="border-color: var(--outline);" />
            <p class="text-center small mb-0">
                &copy; @DateTime.Now.Year SenacGames — Projeto Didático ASP.NET Core MVC
            </p>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>